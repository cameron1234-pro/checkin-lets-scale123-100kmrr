default_platform(:ios)

APP_IDENTIFIER = "com.checkin.mobile"
PROJECT_PATH = "check in.xcodeproj"
SCHEME_NAME = "check in"

platform :ios do
  desc "Validate App Store Connect auth + app access"
  lane :asc_check do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    latest = latest_testflight_build_number(
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0
    )

    UI.success("Connected to App Store Connect. Latest TestFlight build: #{latest}")
  end

  desc "Upload metadata only (no binary, no screenshots)"
  lane :metadata_only do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    deliver(
      app_identifier: APP_IDENTIFIER,
      metadata_path: "fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      force: true
    )
  end

  desc "Upload screenshots only (no binary, no metadata)"
  lane :screenshots_only do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    deliver(
      app_identifier: APP_IDENTIFIER,
      screenshots_path: "fastlane/screenshots",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      force: true
    )
  end

  desc "Build + upload to TestFlight"
  lane :upload_testflight do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    increment_build_number(
      xcodeproj: PROJECT_PATH
    )

    build_app(
      project: PROJECT_PATH,
      scheme: SCHEME_NAME,
      export_method: "app-store"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: File.exist?("fastlane/metadata/en-US/release_notes.txt") ? File.read("fastlane/metadata/en-US/release_notes.txt") : nil
    )
  end

  desc "Prepare App Store version metadata (manual Submit in App Store Connect)"
  lane :prep_release do |options|
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    version = options[:version] || get_version_number(
      xcodeproj: PROJECT_PATH,
      target: SCHEME_NAME
    )

    deliver(
      app_identifier: APP_IDENTIFIER,
      app_version: version,
      metadata_path: "fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      force: true
    )

    UI.success("Release metadata prepared for version #{version}. Open App Store Connect and press Submit when ready.")
  end
end
